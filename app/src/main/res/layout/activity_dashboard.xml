<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_primary"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:elevation="6dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Task Tracker"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back!"
                    android:textSize="13sp"
                    android:textColor="#B3FFFFFF"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical">

                <!-- Profile Pic removed from header as it's now in the bottom bar, but can keep a smaller one or remove it -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivProfilePic"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:visibility="gone" />
                    
                <!-- Sign Out moved to Profile -->
            </LinearLayout>
        </RelativeLayout>

        <!-- Team Info Row -->
        <LinearLayout
            android:id="@+id/teamInfoRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTeamName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Team: Marketing"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvTeamCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Code: 123456"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:background="@drawable/bg_status_chip"
                android:backgroundTint="#33FFFFFF"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />
        </LinearLayout>

        <!-- Stats Cards Row -->
        <LinearLayout
            android:id="@+id/statsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_status_chip"
                android:backgroundTint="#22FFFFFF"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvTotalTasks" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/white" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total" android:textSize="11sp" android:textColor="#B3FFFFFF" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_status_chip"
                android:backgroundTint="#22FFFFFF"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvInProgress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#FFD54F" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="In Progress" android:textSize="11sp" android:textColor="#B3FFFFFF" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_status_chip"
                android:backgroundTint="#22FFFFFF"
                android:padding="10dp">
                <TextView android:id="@+id/tvCompleted" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#69F0AE" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Completed" android:textSize="11sp" android:textColor="#B3FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/filterRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <Button android:id="@+id/btnFilterAll" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="All" android:textSize="11sp" android:singleLine="true" android:textAllCaps="false" android:backgroundTint="@color/primary" android:textColor="@color/white" android:layout_marginEnd="4dp" android:insetTop="0dp" android:insetBottom="0dp" android:minHeight="0dp" android:padding="0dp" />
        <Button android:id="@+id/btnFilterTodo" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="To Do" android:textSize="11sp" android:singleLine="true" android:textAllCaps="false" android:backgroundTint="@color/status_todo" android:textColor="@color/white" android:layout_marginEnd="4dp" android:insetTop="0dp" android:insetBottom="0dp" android:minHeight="0dp" android:padding="0dp" />
        <Button android:id="@+id/btnFilterProgress" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="In Progress" android:textSize="11sp" android:singleLine="true" android:textAllCaps="false" android:backgroundTint="@color/status_in_progress" android:textColor="@color/white" android:layout_marginEnd="4dp" android:insetTop="0dp" android:insetBottom="0dp" android:minHeight="0dp" android:padding="0dp" />
        <Button android:id="@+id/btnFilterDone" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Done" android:textSize="11sp" android:singleLine="true" android:textAllCaps="false" android:backgroundTint="@color/status_completed" android:textColor="@color/white" android:insetTop="0dp" android:insetBottom="0dp" android:minHeight="0dp" android:padding="0dp" />
    </LinearLayout>

    <!-- No Team State -->
    <LinearLayout
        android:id="@+id/noTeamState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👥"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Team Yet"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create a new team or join an existing\none to start tracking tasks together!"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp" />
            
        <Button
            android:id="@+id/btnCreateTeam"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Create Team"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            android:id="@+id/btnJoinTeam"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Join Team"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="@color/accent_teal"
            android:textColor="@color/white"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
            
        <Button
            android:id="@+id/btnSignOutFromNoTeam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign Out"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:elevation="0dp"
            style="?android:attr/borderlessButtonStyle" />
    </LinearLayout>

    <!-- Task List (shown when team is selected) -->
    <ListView
        android:id="@+id/lvTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:clipToPadding="false"
        android:scrollbarStyle="outsideOverlay"
        android:visibility="gone" />

    <!-- Empty Tasks State -->
    <LinearLayout
        android:id="@+id/emptyTaskState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋" android:textSize="48sp" android:layout_marginBottom="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No tasks yet!" android:textSize="18sp" android:textColor="@color/text_secondary" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tap + to create your first task" android:textSize="14sp" android:textColor="@color/text_hint" android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Floating Action Button for Adding Task -->
    <RelativeLayout
        android:id="@+id/fabContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:visibility="gone"
        android:clipToPadding="false">
        
        <!-- This container is just to position the FAB relative to bottom bar -->
    </RelativeLayout>

    <!-- Bottom Action Bar (3 Tabs) -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/tabTasks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tasks"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabMembers"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Members"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabAdd"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_fab"
                android:backgroundTint="@color/primary"
                android:gravity="center"
                android:elevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
