<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:padding="16dp"
    android:layout_marginBottom="10dp"
    android:elevation="2dp">

    <!-- Top Row: Title + Priority -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Task Title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="High"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/priority_high"
            android:background="@drawable/bg_priority_high"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />
    </LinearLayout>

    <!-- Description (if any) -->
    <TextView
        android:id="@+id/tvTaskDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description..."
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Bottom Row: Assignee, Date, Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <!-- Assignee -->
        <TextView
            android:id="@+id/tvAssignee"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👤 Unassigned"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <!-- Due Date -->
        <TextView
            android:id="@+id/tvDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 No date"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="12dp" />

        <!-- Status Chip -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To Do"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_status_chip"
            android:backgroundTint="@color/status_todo"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />
    </LinearLayout>

</LinearLayout>
